# GEMINI_API_KEY: Generated via Google AI Studio settings. Used for server-side dialogue and speech.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# DATABASE_URL: Direct Supabase PostgreSQL connection string (Transaction pooler or direct mode)
# Format: postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:5432/postgres"

# Optional Client-side Supabase configuration
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
